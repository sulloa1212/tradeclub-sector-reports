{# ───────────────────────────────────────────────────────────────────────────
   Injected site navigation bar.

   This is NOT a full page — build.py drops this snippet in right after the
   <body> tag of the model-generated report. It must therefore be fully
   self-contained (its own scoped styles) and must not clash with the report's
   own CSS, so every class is prefixed with `tcnav`.

   Variables:
     sector        e.g. "Energy"
     slug          e.g. "energy"
     current_date  the date of THIS report page (YYYY-MM-DD)
     entries       OTHER kept reports for this sector, newest first
                   (each: {date, label, ...})
─────────────────────────────────────────────────────────────────────────── #}
<style>
.tcnav{position:sticky;top:0;z-index:99999;box-sizing:border-box;display:flex;
  align-items:center;gap:14px;padding:10px 18px;background:#0f172a;color:#f8fafc;
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  font-size:14px;line-height:1.2;box-shadow:0 1px 6px rgba(0,0,0,.25)}
.tcnav *{box-sizing:border-box}
.tcnav a{color:#f8fafc;text-decoration:none}
.tcnav .tcnav-home{display:inline-flex;align-items:center;gap:10px;font-weight:600}
.tcnav .tcnav-home:hover .tcnav-home-text{text-decoration:underline}
.tcnav .tcnav-logo{display:block;width:auto}
.tcnav .tcnav-logo-tc{height:34px}
.tcnav .tcnav-logo-mw{height:30px;margin-left:8px}
@media (max-width:560px){.tcnav .tcnav-logo-tc{height:28px}.tcnav .tcnav-logo-mw{height:24px}}
.tcnav .tcnav-title{font-weight:600;opacity:.85;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tcnav .tcnav-spacer{flex:1}
.tcnav details.tcnav-dd{position:relative}
.tcnav details.tcnav-dd>summary{cursor:pointer;list-style:none;padding:6px 12px;
  border:1px solid rgba(255,255,255,.28);border-radius:7px;background:rgba(255,255,255,.07);white-space:nowrap}
.tcnav details.tcnav-dd>summary::-webkit-details-marker{display:none}
.tcnav details.tcnav-dd>summary::after{content:" ▾";opacity:.7}
.tcnav details.tcnav-dd[open]>summary{background:rgba(255,255,255,.16)}
.tcnav details.tcnav-dd ul{position:absolute;right:0;top:calc(100% + 8px);margin:0;padding:6px;
  list-style:none;background:#ffffff;color:#0f172a;border-radius:10px;
  box-shadow:0 10px 30px rgba(0,0,0,.3);min-width:230px;max-height:60vh;overflow:auto}
.tcnav details.tcnav-dd li a{display:flex;align-items:center;justify-content:space-between;gap:10px;
  padding:8px 10px;border-radius:7px;font-size:13px;white-space:nowrap}
.tcnav details.tcnav-dd li a:hover{background:#f1f5f9}
.tcnav .tcnav-badge{font-size:10px;font-weight:800;letter-spacing:.03em;padding:2px 7px;border-radius:5px;color:#fff}
.tcnav .b-bull{background:#16a34a}
.tcnav .b-bear{background:#dc2626}
.tcnav .b-neut{background:#64748b}
@media print{.tcnav{display:none}}
@media (max-width:560px){.tcnav .tcnav-title{display:none}}
</style>
<div class="tcnav">
  <a class="tcnav-home" href="/">
    <img class="tcnav-logo tcnav-logo-tc" src="/assets/tradeclub-ai.png" alt="Trade Club AI">
    <span class="tcnav-home-text">&larr; All Sectors</span>
  </a>
  <span class="tcnav-title">{{ sector }} &middot; {{ current_date }}</span>
  <span class="tcnav-spacer"></span>
  {% if entries %}
  <details class="tcnav-dd">
    <summary>Previous reports</summary>
    <ul>
      {% for e in entries %}
      <li>
        <a href="/{{ slug }}/{{ e.date }}.html">
          <span>{{ e.date }}</span>
          <span class="tcnav-badge {{ 'b-bull' if e.label == 'BULLISH' else 'b-bear' if e.label == 'BEARISH' else 'b-neut' }}">{{ e.label }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </details>
  {% endif %}
  <img class="tcnav-logo tcnav-logo-mw" src="/assets/mw.png" alt="Michael Wade Trade Coaching">
</div>
