<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Trade Club AI Reports</title>
<style>
  :root{
    --bg:#0b1220; --panel:#111c33; --panel-2:#0f1830; --line:#1e2c4a;
    --ink:#e8eefc; --muted:#9fb0d0;
    --bull:#16a34a; --bull-soft:rgba(22,163,74,.16);
    --bear:#dc2626; --bear-soft:rgba(220,38,38,.16);
    --neut:#64748b; --neut-soft:rgba(100,116,139,.18);
  }
  *{box-sizing:border-box}
  html,body{margin:0}
  body{
    background:radial-gradient(1200px 600px at 50% -10%, #16223f 0%, var(--bg) 55%);
    color:var(--ink); min-height:100vh;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    line-height:1.5;
  }
  .wrap{max-width:1080px;margin:0 auto;padding:40px 20px 64px}
  header.hero{position:relative;text-align:center;margin-bottom:34px;padding-top:6px}
  .hero-tc{display:block;width:auto;height:154px;margin:0 auto 16px}
  .hero-mw{position:absolute;top:0;right:0;height:58px;width:auto;display:block}
  @media (max-width:560px){.hero-tc{height:104px}.hero-mw{height:42px}}
  header.hero h1{font-size:30px;margin:0 0 8px;letter-spacing:-.01em}
  header.hero p{margin:0;color:var(--muted);font-size:15px}
  .stamp{display:inline-block;margin-top:12px;font-size:12px;color:var(--muted);
    border:1px solid var(--line);border-radius:999px;padding:5px 12px;background:rgba(255,255,255,.02)}

  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:18px}
  .card{display:block;text-decoration:none;color:inherit;background:var(--panel);
    border:1px solid var(--line);border-top:4px solid var(--neut);border-radius:14px;
    padding:18px 18px 16px;transition:transform .12s ease, box-shadow .12s ease, border-color .12s ease}
  .card:hover{transform:translateY(-3px);box-shadow:0 14px 34px rgba(0,0,0,.35)}
  .card.bull{border-top-color:var(--bull)}
  .card.bear{border-top-color:var(--bear)}
  .card.neut{border-top-color:var(--neut)}

  .card .top{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px}
  .card h2{font-size:18px;margin:0;letter-spacing:-.01em}
  .badge{font-size:11px;font-weight:800;letter-spacing:.04em;padding:4px 9px;border-radius:6px;color:#fff;white-space:nowrap}
  .badge.bull{background:var(--bull)} .badge.bear{background:var(--bear)} .badge.neut{background:var(--neut)}

  .scorerow{display:flex;align-items:baseline;gap:8px;margin:2px 0 10px}
  .score{font-size:26px;font-weight:800;font-variant-numeric:tabular-nums}
  .score.bull{color:#4ade80} .score.bear{color:#f87171} .score.neut{color:#cbd5e1}
  .conv{font-size:12px;color:var(--muted)}

  /* −100 … +100 direction scale: red (bearish) → green (bullish); marker = score */
  .meter{position:relative;height:10px;border-radius:999px;margin:16px 0 6px;
    background:linear-gradient(to right,#ef4444 0%,#f59e0b 50%,#22c55e 100%)}
  .meter .tick{position:absolute;left:50%;top:-3px;bottom:-3px;width:1px;background:rgba(255,255,255,.4)}
  .meter .mark{position:absolute;top:50%;transform:translate(-50%,-50%);
    min-width:30px;height:22px;padding:0 6px;border-radius:999px;background:#fff;
    border:2px solid var(--bg);display:flex;align-items:center;justify-content:center;
    font-size:11px;font-weight:800;color:#0b1220;font-variant-numeric:tabular-nums;
    box-shadow:0 1px 5px rgba(0,0,0,.45)}
  .scale{display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin:0 0 12px}

  .card-main{display:block;text-decoration:none;color:inherit}
  .tldr{font-size:13.5px;color:var(--muted);margin:0}
  .arrow{color:var(--muted);font-size:13px;margin-top:12px}
  .card:hover .arrow{color:var(--ink)}

  /* Per-card "Previous reports" dropdown — compact, no extra grid space */
  .card-hist{margin-top:12px;border-top:1px solid var(--line);padding-top:10px}
  .card-hist>summary{cursor:pointer;list-style:none;font-size:12px;color:var(--muted);
    display:inline-flex;align-items:center;gap:6px;user-select:none}
  .card-hist>summary::-webkit-details-marker{display:none}
  .card-hist>summary::after{content:"▾";font-size:10px;opacity:.7}
  .card-hist[open]>summary{color:var(--ink)}
  .card-hist[open]>summary::after{content:"▴"}
  .card-hist ul{list-style:none;margin:10px 0 2px;padding:0;display:flex;flex-direction:column;gap:5px}
  .card-hist li a{display:flex;align-items:center;justify-content:space-between;gap:10px;
    text-decoration:none;color:var(--ink);font-size:12.5px;padding:6px 9px;border-radius:7px;
    background:var(--panel-2);border:1px solid var(--line);
    font-variant-numeric:tabular-nums;transition:border-color .12s ease}
  .card-hist li a:hover{border-color:var(--muted)}
  .hbadge{font-size:9px;font-weight:800;letter-spacing:.03em;padding:2px 6px;border-radius:4px;color:#fff;white-space:nowrap}
  .hbadge.bull{background:var(--bull)} .hbadge.bear{background:var(--bear)} .hbadge.neut{background:var(--neut)}

  .empty{text-align:center;color:var(--muted);border:1px dashed var(--line);
    border-radius:14px;padding:40px 20px}

  footer.disc{margin-top:34px;font-size:12px;color:var(--muted);
    border-top:1px solid var(--line);padding-top:18px;line-height:1.6}
  footer.disc strong{color:#cbd5e1}
  footer.disc a{color:#29b6f6;text-decoration:underline}
</style>
</head>
<body>
  <div class="wrap">
    <header class="hero">
      <img class="hero-mw" src="/assets/mw.png" alt="Michael Wade Trade Coaching">
      <img class="hero-tc" src="/assets/tradeclub-ai.png" alt="Trade Club AI">
      <h1>Trade Club AI Reports</h1>
      <p>Daily direction calls and top stock picks across sectors &middot; 3-day to 6-week horizon</p>
      <div class="stamp">Generated {{ generated }}</div>
    </header>

    {% if cards %}
    <main class="grid">
      {% for c in cards %}
      {% set cls = 'bull' if c.label == 'BULLISH' else 'bear' if c.label == 'BEARISH' else 'neut' %}
      {% set s = c.direction_score | int %}
      {# marker position on the −100..+100 scale: -100 -> 0%, 0 -> 50%, +100 -> 100% (clamped so the bubble stays on the bar) #}
      {% set pos = [[ (s + 100) / 2, 3 ] | max, 97] | min %}
      <div class="card {{ cls }}">
        <a class="card-main" href="/{{ c.slug }}/">
          <div class="top">
            <h2>{{ c.sector }}</h2>
            <span class="badge {{ cls }}">{{ c.label }}</span>
          </div>
          <div class="scorerow">
            <span class="score {{ cls }}">{{ '%+d' | format(s) }}</span>
            <span class="conv">{{ c.conviction }} conviction</span>
          </div>
          <div class="meter">
            <div class="tick"></div>
            <div class="mark" style="left:{{ pos }}%">{{ '%+d' | format(s) }}</div>
          </div>
          <div class="scale"><span>&minus;100</span><span>0</span><span>+100</span></div>
          <p class="tldr">{{ c.tldr }}</p>
          <div class="arrow">View full report &rarr;</div>
        </a>
        {% if c.history %}
        <details class="card-hist">
          <summary>Previous reports ({{ c.history | length }})</summary>
          <ul>
            {% for h in c.history %}
            {% set hcls = 'bull' if h.label == 'BULLISH' else 'bear' if h.label == 'BEARISH' else 'neut' %}
            <li>
              <a href="/{{ c.slug }}/{{ h.date }}.html">
                <span>{{ h.date }}</span>
                <span class="hbadge {{ hcls }}">{{ h.label }}</span>
              </a>
            </li>
            {% endfor %}
          </ul>
        </details>
        {% endif %}
      </div>
      {% endfor %}
    </main>
    {% else %}
    <div class="empty">No reports yet. The first build will populate this page.</div>
    {% endif %}

    <footer class="disc">
      <strong>Educational purposes only — not investment advice.</strong> The Freedom Management Group, Inc. d/b/a Michael Wade Trade Coaching is not a broker, adviser, or fiduciary. All trades are at your own risk; past performance does not guarantee future results. Options involve substantial risk and you can lose more than your investment — always paper trade first before risking real money. <strong>This report is generated with the assistance of artificial intelligence, and AI can make mistakes.</strong> The analysis, prices, technical levels, earnings dates, probabilities, and figures herein are produced by automated models that may misinterpret data, rely on sources that are outdated or inaccurate, or generate confident-sounding output that is simply wrong. Probabilities are options-implied estimates, not predictions, and real-world tails are fatter than a normal curve. Nothing here has been independently verified by a licensed professional. Always confirm every data point, price, and date against your own brokerage and primary sources before acting, and treat this report as a starting point for your own research — never as a substitute for your own judgment. By using our services, you agree to our <a href="https://www.mwtradecoach.com/terms-and-conditions" target="_blank" rel="noopener">Terms &amp; Conditions</a> and <a href="https://www.mwtradecoach.com/privacy-policy" target="_blank" rel="noopener">Privacy Policy</a>.
    </footer>
  </div>
</body>
</html>
