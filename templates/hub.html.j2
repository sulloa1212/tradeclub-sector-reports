<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Swing-Trade Sector Reports</title>
<style>
  :root{
    --bg:#0b1220; --panel:#111c33; --panel-2:#0f1830; --line:#1e2c4a;
    --ink:#e8eefc; --muted:#9fb0d0;
    --bull:#16a34a; --bull-soft:rgba(22,163,74,.16);
    --bear:#dc2626; --bear-soft:rgba(220,38,38,.16);
    --neut:#64748b; --neut-soft:rgba(100,116,139,.18);
  }
  *{box-sizing:border-box}
  html,body{margin:0}
  body{
    background:radial-gradient(1200px 600px at 50% -10%, #16223f 0%, var(--bg) 55%);
    color:var(--ink); min-height:100vh;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    line-height:1.5;
  }
  .wrap{max-width:1080px;margin:0 auto;padding:40px 20px 64px}
  header.hero{text-align:center;margin-bottom:34px}
  header.hero h1{font-size:30px;margin:0 0 8px;letter-spacing:-.01em}
  header.hero p{margin:0;color:var(--muted);font-size:15px}
  .stamp{display:inline-block;margin-top:12px;font-size:12px;color:var(--muted);
    border:1px solid var(--line);border-radius:999px;padding:5px 12px;background:rgba(255,255,255,.02)}

  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:18px}
  .card{display:block;text-decoration:none;color:inherit;background:var(--panel);
    border:1px solid var(--line);border-top:4px solid var(--neut);border-radius:14px;
    padding:18px 18px 16px;transition:transform .12s ease, box-shadow .12s ease, border-color .12s ease}
  .card:hover{transform:translateY(-3px);box-shadow:0 14px 34px rgba(0,0,0,.35)}
  .card.bull{border-top-color:var(--bull)}
  .card.bear{border-top-color:var(--bear)}
  .card.neut{border-top-color:var(--neut)}

  .card .top{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px}
  .card h2{font-size:18px;margin:0;letter-spacing:-.01em}
  .badge{font-size:11px;font-weight:800;letter-spacing:.04em;padding:4px 9px;border-radius:6px;color:#fff;white-space:nowrap}
  .badge.bull{background:var(--bull)} .badge.bear{background:var(--bear)} .badge.neut{background:var(--neut)}

  .scorerow{display:flex;align-items:baseline;gap:8px;margin:2px 0 10px}
  .score{font-size:26px;font-weight:800;font-variant-numeric:tabular-nums}
  .score.bull{color:#4ade80} .score.bear{color:#f87171} .score.neut{color:#cbd5e1}
  .conv{font-size:12px;color:var(--muted)}

  /* −100 … +100 direction meter */
  .meter{position:relative;height:8px;border-radius:999px;background:var(--panel-2);
    border:1px solid var(--line);margin:8px 0 12px;overflow:hidden}
  .meter .center{position:absolute;left:50%;top:0;bottom:0;width:1px;background:rgba(255,255,255,.25)}
  .meter .fill{position:absolute;top:0;bottom:0}
  .meter .fill.bull{background:var(--bull)} .meter .fill.bear{background:var(--bear)} .meter .fill.neut{background:var(--neut)}

  .tldr{font-size:13.5px;color:var(--muted);margin:0}
  .arrow{color:var(--muted);font-size:13px;margin-top:12px}
  .card:hover .arrow{color:var(--ink)}

  .empty{text-align:center;color:var(--muted);border:1px dashed var(--line);
    border-radius:14px;padding:40px 20px}

  footer.disc{margin-top:34px;font-size:12px;color:var(--muted);
    border-top:1px solid var(--line);padding-top:18px;line-height:1.6}
  footer.disc strong{color:#cbd5e1}
</style>
</head>
<body>
  <div class="wrap">
    <header class="hero">
      <h1>Swing-Trade Sector Reports</h1>
      <p>Daily direction calls and top stock picks across sectors &middot; 3-day to 6-week horizon</p>
      <div class="stamp">Generated {{ generated }}</div>
    </header>

    {% if cards %}
    <main class="grid">
      {% for c in cards %}
      {% set cls = 'bull' if c.label == 'BULLISH' else 'bear' if c.label == 'BEARISH' else 'neut' %}
      {% set s = c.direction_score | int %}
      {# meter geometry: 0 sits at center (50%); positive fills right, negative fills left #}
      {% set half = (s | abs) / 2 %}
      <a class="card {{ cls }}" href="/{{ c.slug }}/">
        <div class="top">
          <h2>{{ c.sector }}</h2>
          <span class="badge {{ cls }}">{{ c.label }}</span>
        </div>
        <div class="scorerow">
          <span class="score {{ cls }}">{{ '%+d' | format(s) }}</span>
          <span class="conv">{{ c.conviction }} conviction</span>
        </div>
        <div class="meter">
          <div class="fill {{ cls }}" style="{% if s >= 0 %}left:50%;width:{{ half }}%{% else %}right:50%;width:{{ half }}%{% endif %}"></div>
          <div class="center"></div>
        </div>
        <p class="tldr">{{ c.tldr }}</p>
        <div class="arrow">View full report &rarr;</div>
      </a>
      {% endfor %}
    </main>
    {% else %}
    <div class="empty">No reports yet. The first build will populate this page.</div>
    {% endif %}

    <footer class="disc">
      <strong>Educational analysis, not personal financial advice.</strong>
      These reports reflect probabilities, not certainties; markets can move against any thesis,
      and you are responsible for your own decisions and risk management. All data is time-stamped
      and goes stale quickly — always confirm with a live source before acting.
    </footer>
  </div>
</body>
</html>
